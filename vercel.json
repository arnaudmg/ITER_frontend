    },
    {
      "source": "/es/ressources/glossaire/:slug",
      "destination": "/es/ressources/glossaire",
      "permanent": true
    },
    {
      "source": "/category/:path*",
      "destination": "/ressources/blog",
      "permanent": true
    },
    {
      "source": "/en/category/:path*",
      "destination": "/en/ressources/blog",
      "permanent": true
    },
    {
      "source": "/es/category/:path*",
      "destination": "/es/ressources/blog",
      "permanent": true
    }
  ]
}
